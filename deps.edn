{:paths ["src"]
 ;; Composition, not reimplementation: gossip/bitswap SEMANTICS come from
 ;; kotoba-lang/net, chain walk/verify from commit-dag, CID-verified ingest +
 ;; the generic tag-42 hydrate walk from kotoba-client (ipld transitively).
 :deps {io.github.kotoba-lang/net {:git/sha "20d99d1e0ed5ca4e13d00c383b7d522dd7f7bb18"}
        io.github.kotoba-lang/commit-dag {:git/sha "05cc0473dce76539edab46d9fb8cf785f6ff6117"}
        io.github.kotoba-lang/kotoba-client {:git/sha "92cbadab8e17eef963d948306b46b2fa54874106"}}
 :aliases
 {:test {:extra-paths ["test"]
         ;; e2e tests sync a REAL kotobase-peer commit chain (kotobase-engine
         ;; until ADR-2607050700) and read it back on the receiver via
         ;; prolly-tree -- these two are test-only.
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                      io.github.kotoba-lang/kotobase-peer
                      {:git/sha "60d922b9c490546e8df2fa364e30f3fb25d50a59"}
                      io.github.kotoba-lang/prolly-tree
                      {:git/sha "8da6d1e17fe8efe9294055f5ec242c439329de89"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}}}
